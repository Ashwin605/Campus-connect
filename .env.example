# CampusConnect Production Environment Variables

# The Secret Key used for session security and CSRF tokens. Generate a secure random string.
SECRET_KEY=replace-this-with-a-very-long-secure-random-string

# The Database URL. For local dev, you can leave it empty to use SQLite.
# For production (e.g. Render, Supabase, Heroku), provide your PostgreSQL URI.
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=

# Port to bind the application (PaaS providers usually inject this automatically)
PORT=8080
